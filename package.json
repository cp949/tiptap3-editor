{
  "name": "tiptap3-editor",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "dev": "turbo run dev",
    "release": "changeset publish",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --write --unsafe",
    "format": "biome format --write .",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@biomejs/biome": "2.4.11",
    "turbo": "^2.9.6",
    "typescript": "6.0.2"
  },
  "pnpm": {
    "overrides": {
      "rollup": "4.59.0"
    }
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
